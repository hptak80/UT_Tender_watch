"""
Lokale Zugangsdaten für local_review.py.

WICHTIG: Diese Datei (local_secrets.py, OHNE ".example") enthält echte
Zugangsdaten und darf NIEMALS zu GitHub hochgeladen werden! Sie ist in
.gitignore eingetragen, damit sie bei einem `git add .` übersprungen wird -
falls du Dateien aber per Drag&Drop im Browser hochlädst, lade diese Datei
einfach nicht mit hoch.

Einrichtung:
1. Diese Datei kopieren und umbenennen zu: local_secrets.py
2. Die Platzhalter unten durch deine echten Werte ersetzen.
"""

# --- GitHub (zum Lesen/Leeren der Warteschlange) ---------------------------
# Personal Access Token mit Lese-/Schreibzugriff auf den Repo-Inhalt.
# Erstellen unter: https://github.com/settings/tokens
#   -> "Fine-grained tokens" -> "Generate new token"
#   -> Repository access: nur dieses eine Repo auswählen
#   -> Permissions: "Contents" = Read and write
GITHUB_OWNER = "DEIN-GITHUB-USERNAME"
GITHUB_REPO = "tender-watch"
GITHUB_TOKEN = "github_pat_..."
GITHUB_BRANCH = "main"

# --- Ollama (lokales Modell, z.B. über Hermes gestartet) -------------------
# Prüfe mit "ollama list" in einem Terminal den EXAKTEN Modell-Tag.
OLLAMA_URL = "http://localhost:11434"
OLLAMA_MODEL = "qwen3"  # z.B. "qwen3:8b" - exakten Tag aus "ollama list" eintragen

# --- Benachrichtigung (kann identisch zu den GitHub-Secrets sein) ----------
SMTP_HOST = ""
SMTP_PORT = "587"
SMTP_USER = ""
SMTP_PASS = ""
EMAIL_TO = ""

TELEGRAM_BOT_TOKEN = ""
TELEGRAM_CHAT_ID = ""
